{
    "version": 2,
    "builds": [
        { "src": "/api/index.php", "use": "vercel-php@0.7.2" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(build|css|js|images|nas)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://nas-student-portal-84e2tw6az-kimmyyyy1s-projects.vercel.app",
        "ASSET_URL": "https://nas-student-portal-84e2tw6az-kimmyyyy1s-projects.vercel.app"
    }
}