{
    "version": 2,
    "framework": "laravel",
    "builds": [
        { "src": "/api/index.php", "use": "vercel-php@0.7.2" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        {
            "src": "/(build|assets|css|js|images|storage|nas|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}